{
  "name": "React Multi-Service Dev",
  "dockerComposeFile": "docker-compose.yml",
  "service": "app",
  "workspaceFolder": "/workspace",
  "forwardPorts": [3000, 6006, 8080, 3306, 6379],
  "portsAttributes": {
    "3000": { "label": "Next.js" },
    "6006": { "label": "Storybook" },
    "8080": { "label": "Go Service" },
    "3306": { "label": "MySQL" },
    "6379": { "label": "Redis" }
  },
  "postCreateCommand": "cd boldpracttice && npm install",
  "customizations": {
    "vscode": {
      "extensions": [
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "bradlc.vscode-tailwindcss",
        "csstools.postcss",
        "golang.go"
      ],
      "settings": {
        "editor.formatOnSave": true,
        "editor.defaultFormatter": "esbenp.prettier-vscode",
        "[go]": {
          "editor.defaultFormatter": "golang.go"
        }
      }
    }
  }
}
